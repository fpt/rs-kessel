namespace kessel_core {
    [Throws=AgentError]
    Agent agent_new(AgentConfig config, MutationApprover? approver);
};

// How the frontend answers a mutation (file write / shell command) the backend
// wants to run in its own process. Returned by [MutationApprover.approve].
enum ApprovalDecision {
    "AllowOnce",
    "AllowSession",
    "Deny",
};

// Implemented by the frontend. Called synchronously (on a backend-servicing
// thread) whenever the backend asks permission for a mutation; blocks the turn
// until it returns. When no approver is supplied to [agent_new], the backend is
// told to run autonomously (no approval requests are raised) — so a frontend
// that wants an approval gate MUST pass one.
[Trait, WithForeign]
interface MutationApprover {
    ApprovalDecision approve(string action, string target);
};

[Error]
enum AgentError {
    "NetworkError",
    "ParseError",
    "ConfigError",
    "InternalError",
};

dictionary McpServerConfig {
    string command;
    sequence<string> args;
    string? url;
};

dictionary AgentConfig {
    string? model_path;
    string base_url;
    string model;
    string? api_key;
    boolean use_harmony_template;
    f32? temperature;
    u32 max_tokens;
    u32 context_window;
    string? language;
    string? working_dir;
    string? reasoning_effort;
    string? inference_engine;
    sequence<McpServerConfig> mcp_servers;
};

dictionary AgentResponse {
    string content;
    string role;
    boolean is_final;
    sequence<string>? keywords;
    string? reasoning;
    u64 input_tokens;
    u64 output_tokens;
    u64 total_tokens;
    f32 context_percent;
    u32? suggested_next_check_seconds;
};

dictionary GoalStatus {
    string condition;
    u64 elapsed_seconds;
    u32 turns_evaluated;
    string? last_reason;
};

dictionary GoalEvaluation {
    boolean met;
    string reason;
};

dictionary CaptureRequest {
    string id;
    u32? window_id;
    f64? crop_x;
    f64? crop_y;
    f64? crop_w;
    f64? crop_h;
    boolean? detect;
    boolean? apply_ocr;
    string? search_keywords;
};

interface Agent {
    [Throws=AgentError]
    AgentResponse step(string user_input);

    string? process_backchannel(string partial_input, u64 pause_ms);

    void reset();

    string get_conversation_history();

    void set_system_prompt(string prompt);

    void add_skill(string name, string description, string prompt);

    [Throws=AgentError]
    AgentResponse step_with_allowed_tools(string user_input, sequence<string> allowed_tools);

    [Throws=AgentError]
    AgentResponse observe(string prompt, sequence<string> allowed_tools);

    sequence<CaptureRequest> drain_capture_requests();

    void submit_capture_result(string id, string image_base64, string metadata_json);

    void push_situation_message(string text, string source, string session_id);

    void set_goal(string condition);

    void clear_goal();

    GoalStatus? goal_status();

    [Throws=AgentError]
    GoalEvaluation evaluate_goal();
};

// Standalone fantasy-console player: load a game and drive it from a host
// render loop (60 Hz tick + keyboard->gamepad). No LLM/agent dependency.
interface VmPlayer {
    constructor();

    // Compile/assemble `source` (dialect chosen by `path`'s extension),
    // load the ROM, run reset. "" on success, else an error/diagnostics string.
    string load(string source, string path);

    // Advance one frame with `buttons` held (bitfield). No-op until a ROM loads.
    // The ROM's pause button (default START) freezes/resumes play.
    void tick(u8 buttons);

    // Current framebuffer as dim*dim*4 RGBA bytes, or null if no ROM is loaded.
    bytes? framebuffer_rgba();

    u32 screen_dim();

    boolean has_rom();

    boolean is_halted();

    // Whether play is currently paused (the pause button was pressed).
    boolean is_paused();

    // The loaded ROM's control-layout metadata as JSON, for the host UI to
    // label buttons / lay out an on-screen pad (VM-irrelevant metadata).
    string controls_json();
};
